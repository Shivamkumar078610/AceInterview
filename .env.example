# AceInterview AI Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================
# NEXT.JS
# ============================================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars-change-this

# ============================================================
# DATABASE (Neon PostgreSQL recommended)
# ============================================================
DATABASE_URL="postgresql://username:password@host/database?sslmode=require"

# ============================================================
# REDIS (Upstash recommended)
# ============================================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ============================================================
# AI - OpenRouter (REQUIRED)
# ============================================================
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# ============================================================
# OAUTH PROVIDERS
# ============================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# LinkedIn (optional)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# ============================================================
# STRIPE (Payment Processing)
# ============================================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_ENTERPRISE_PRICE_ID=price_your-enterprise-price-id
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ============================================================
# EMAIL (Resend)
# ============================================================
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@aceinterview.ai

# ============================================================
# FILE STORAGE (Cloudinary)
# ============================================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ============================================================
# DEEPGRAM (Voice Interviews - Optional)
# ============================================================
DEEPGRAM_API_KEY=your-deepgram-api-key
DEEPGRAM_PROJECT_ID=your-deepgram-project-id

# ============================================================
# APP SETTINGS
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="AceInterview AI"

# Free tier limits
FREE_TIER_MONTHLY_INTERVIEWS=5
FREE_TIER_MONTHLY_AI_TOKENS=50000

# Pro tier limits
PRO_TIER_MONTHLY_INTERVIEWS=100
PRO_TIER_MONTHLY_AI_TOKENS=2000000

# ============================================================
# OPTIONAL: PISTON CODE EXECUTION (Uses public API by default)
# ============================================================
# PISTON_API_URL=https://emkc.org/api/v2/piston
# Override with self-hosted URL in production

# ============================================================
# OPTIONAL: SENTRY MONITORING
# ============================================================
# SENTRY_DSN=https://your-sentry-dsn
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn
